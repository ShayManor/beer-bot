<?xml version="1.0"?>
<robot name="wave_rover" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="$(find autonomous_rover)/description/urdf/wave_rover.ros2_control.xacro"/>
  <xacro:include filename="$(find autonomous_rover)/description/urdf/wave_rover.gazebo.xacro"/>

  <!-- Generated geometry + inertials (data, not hardcoded). -->
  <xacro:property name="geom" value="${xacro.load_yaml('$(find autonomous_rover)/description/config/geometry.yaml')}"/>
  <xacro:property name="inert" value="${xacro.load_yaml('$(find autonomous_rover)/description/config/inertial_params.yaml')}"/>
  <xacro:property name="bl" value="${inert['base_link']}"/>
  <xacro:property name="wh" value="${inert['wheel']}"/>
  <xacro:property name="wc" value="${geom['wheel_centers']}"/>
  <xacro:property name="bbox" value="${geom['chassis_bbox']}"/>
  <xacro:property name="bcenter" value="${geom['chassis_center']}"/>

  <!-- Spec constants + mount estimates (metres). -->
  <xacro:property name="wheel_radius" value="0.040"/>
  <xacro:property name="wheel_width" value="0.0425"/>
  <xacro:property name="camera_height" value="0.1905"/>   <!-- 7.5 in, measured -->
  <xacro:property name="camera_x" value="${bbox[0]/2}"/>   <!-- front face of chassis -->
  <xacro:property name="imu_xyz" value="0.0 0.0 0.02"/>    <!-- ESP32 board; measure on build -->
  <xacro:property name="mesh" value="file://$(find autonomous_rover)/description/meshes"/>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/><child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh}/chassis.stl"/></geometry>
    </visual>
    <collision>
      <origin xyz="${bcenter[0]} ${bcenter[1]} ${bcenter[2]}" rpy="0 0 0"/>
      <geometry><box size="${bbox[0]} ${bbox[1]} ${bbox[2]}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="${bl['com'][0]} ${bl['com'][1]} ${bl['com'][2]}" rpy="0 0 0"/>
      <mass value="${bl['mass']}"/>
      <inertia ixx="${bl['inertia']['ixx']}" ixy="${bl['inertia']['ixy']}" ixz="${bl['inertia']['ixz']}"
               iyy="${bl['inertia']['iyy']}" iyz="${bl['inertia']['iyz']}" izz="${bl['inertia']['izz']}"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="name xyz">
    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="${mesh}/wheel.stl"/></geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wh['mass']}"/>
        <inertia ixx="${wh['inertia']['ixx']}" ixy="${wh['inertia']['ixy']}" ixz="${wh['inertia']['ixz']}"
                 iyy="${wh['inertia']['iyy']}" iyz="${wh['inertia']['iyz']}" izz="${wh['inertia']['izz']}"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/><child link="${name}_wheel_link"/>
      <origin xyz="${xyz[0]} ${xyz[1]} ${xyz[2]}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left" xyz="${wc['front_left']}"/>
  <xacro:wheel name="front_right" xyz="${wc['front_right']}"/>
  <xacro:wheel name="rear_left" xyz="${wc['rear_left']}"/>
  <xacro:wheel name="rear_right" xyz="${wc['rear_right']}"/>

  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="${camera_x} 0 ${camera_height - wheel_radius}" rpy="0 0 0"/>
  </joint>
  <link name="camera_link_optical"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/><child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin xyz="${imu_xyz}" rpy="0 0 0"/>
  </joint>

  <xacro:wave_rover_ros2_control/>
  <xacro:wave_rover_gazebo camera_frame="camera_link_optical" imu_frame="imu_link"/>
</robot>
